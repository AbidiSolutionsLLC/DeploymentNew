<!DOCTYPE html>
<html>
<%- include('../layouts/head') %>

    <body>
        <div class="wrapper">
            <div class="container">
                <%- include('../layouts/header') %>

                    <div class="content">
                        <h1>Ticket Assigned to You</h1>
                        <p>Hello <%= name %>,</p>
                        <p>A support ticket has been assigned to you for review. Please find the details below:</p>

                        <div class="info-box">
                            <p><strong>Ticket ID:</strong> #<%= ticket.ticketID %>
                            </p>
                            <p><strong>Subject:</strong>
                                <%= ticket.subject %>
                            </p>
                            <p><strong>Status:</strong>
                                <%= ticket.status %>
                            </p>
                            <p><strong>Priority:</strong> <span style="color: #ef4444; font-weight: 600;">
                                    <%= ticket.priority %>
                                </span></p>
                            <p><strong>Submitted By:</strong>
                                <%= ticket.emailAddress %>
                            </p>
                        </div>

                        <p><strong>Description:</strong></p>
                        <p style="background: #f1f5f9; padding: 12px; border-radius: 8px; color: #475569;">
                            <%= ticket.description %>
                        </p>

                        <div style="text-align: center; margin-top: 32px;">
                            <a href="<%= process.env.FRONTEND_URL %>/admin/tickets/<%= ticket._id %>" class="btn">Manage
                                Ticket</a>
                        </div>
                    </div>

                    <%- include('../layouts/footer') %>
            </div>
        </div>
    </body>

</html>