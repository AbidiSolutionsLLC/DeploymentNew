<!DOCTYPE html>
<html>
<%- include('../layouts/head') %>

    <body>
        <div class="wrapper">
            <div class="container">
                <%- include('../layouts/header') %>

                    <div class="content">
                        <h1>Ticket Received</h1>
                        <p>Hello,</p>
                        <p>We have received your support ticket. Our team will review it shortly. Here are the details:
                        </p>

                        <div class="info-box">
                            <p><strong>Ticket ID:</strong> #<%= ticket.ticketID %>
                            </p>
                            <p><strong>Subject:</strong>
                                <%= ticket.subject %>
                            </p>
                            <p><strong>Status:</strong> <span style="color: #16a34a; font-weight: 600;">
                                    <%= ticket.status %>
                                </span></p>
                            <p><strong>Priority:</strong>
                                <%= ticket.priority %>
                            </p>
                        </div>

                        <p><strong>Description:</strong></p>
                        <p style="background: #f1f5f9; padding: 12px; border-radius: 8px; color: #475569;">
                            <%= ticket.description %>
                        </p>

                        <p>You can track the status of your ticket by logging into the portal.</p>

                        <div style="text-align: center; margin-top: 32px;">
                            <a href="<%= process.env.FRONTEND_URL %>/ticket-details/<%= ticket._id %>" class="btn">View
                                Ticket</a>
                        </div>
                    </div>

                    <%- include('../layouts/footer') %>
            </div>
        </div>
    </body>

</html>