<!DOCTYPE html>
<html>
<%- include('../layouts/head') %>

    <body>
        <div class="wrapper">
            <div class="container">
                <%- include('../layouts/header') %>

                    <div class="content">
                        <h1>Missing Checkout</h1>
                        <p>Hello <%= name %>,</p>
                        <p>It seems you forgot to check out today. Your session is still active for <strong>
                                <%= date %>
                            </strong>.</p>

                        <p>Please log in and update your attendance status to ensure your working hours are recorded
                            correctly.</p>

                        <div style="text-align: center; margin-top: 32px;">
                            <a href="<%= process.env.FRONTEND_URL %>/dashboard" class="btn">Check Out Now</a>
                        </div>
                    </div>

                    <%- include('../layouts/footer') %>
            </div>
        </div>
    </body>

</html>