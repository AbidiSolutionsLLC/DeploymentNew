<!DOCTYPE html>
<html>
<%- include('../layouts/head') %>

    <body>
        <div class="wrapper">
            <div class="container">
                <%- include('../layouts/header') %>

                    <div class="content">
                        <h1>Welcome to Abidi Pro!</h1>
                        <p>Hello <%= name %>,</p>
                        <p>Your account has been successfully created. We are excited to have you on board.</p>

                        <p>You can now access the portal to manage your tasks, attendance, and more.</p>

                        <div class="info-box">
                            <p><strong>Email:</strong>
                                <%= email %>
                            </p>
                            <p><strong>Role:</strong>
                                <%= role %>
                            </p>
                        </div>

                        <div style="text-align: center; margin-top: 32px;">
                            <a href="<%= loginURL %>" class="btn">Login to Portal</a>
                        </div>

                        <p style="font-size: 14px; color: #64748b; margin-top: 24px;">
                            If you did not request this account, please ignore this email or contact support.
                        </p>
                    </div>

                    <%- include('../layouts/footer') %>
            </div>
        </div>
    </body>

</html>