<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= subject %></title>
    <style>
        /* Import Inter font */
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: #CDD9EA; /* var(--color-bg-app) */
            margin: 0;
            padding: 0;
            -webkit-font-smoothing: antialiased;
            color: #1e293b; /* var(--color-text-primary) */
        }

        .wrapper {
            width: 100%;
            background-color: #CDD9EA;
            padding: 40px 20px;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff; /* var(--color-bg-secondary) */
            border-radius: 16px; /* var(--radius-2xl) -> 1.25rem ~ 20px */
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1); /* var(--shadow-md) */
            overflow: hidden;
        }

        .header {
            background-color: #ffffff;
            padding: 32px 40px;
            text-align: center;
            border-bottom: 1px solid #f1f5f9; /* var(--color-border-secondary) */
        }

        .logo {
            font-size: 24px; /* var(--text-2xl) */
            font-weight: 700; /* var(--font-bold) */
            color: #3b82f6; /* var(--color-brand-primary) */
            text-decoration: none;
            display: inline-block;
        }

        .content {
            padding: 40px;
            font-size: 16px; /* var(--text-base) */
            line-height: 1.5; /* var(--leading-normal) */
            color: #1e293b;
        }

        h1 {
            font-size: 24px; /* var(--text-2xl) */
            font-weight: 700;
            color: #0f172a; /* var(--color-text-heading) */
            margin-top: 0;
            margin-bottom: 24px;
        }

        p {
            margin-bottom: 24px;
            color: #475569; /* var(--color-text-secondary) */
        }

        .btn {
            display: inline-block;
            background-color: #3b82f6; /* var(--color-brand-primary) */
            color: #ffffff;
            font-weight: 500;
            text-decoration: none;
            padding: 12px 24px;
            border-radius: 8px; /* var(--radius-md) */
            margin-top: 10px;
            margin-bottom: 10px;
        }
        
        .btn:hover {
            background-color: #2563eb;
        }

        .info-box {
            background-color: #f8fafc; /* var(--color-bg-tertiary) */
            border-left: 4px solid #3b82f6;
            padding: 16px;
            border-radius: 8px;
            margin-bottom: 24px;
        }

        .footer {
            background-color: #f8fafc;
            padding: 24px;
            text-align: center;
            font-size: 12px; /* var(--text-xs) */
            color: #94a3b8; /* var(--color-text-muted) */
            border-top: 1px solid #f1f5f9;
        }

        .footer a {
            color: #3b82f6;
            text-decoration: none;
        }

        /* Mobile Responsive */
        @media only screen and (max-width: 600px) {
            .wrapper {
                padding: 20px 10px;
            }
            .content {
                padding: 24px;
            }
            .header {
                padding: 24px;
            }
        }
    </style>
</head>
